{
  "id": "fan-control",
  "displayName": "风扇控制",
  "summary": "管理风扇转速预设，支持自动、全速和自定义策略",
  "version": "1.0.3",
  "minHostVersion": "1.0.2",
  "pluginKitVersion": 1,
  "bundleRelativePath": "FanControl.bundle",
  "factoryClass": "FanControlPlugin.FanControlPluginFactory",
  "build": {
    "project": "../../MacTools.xcodeproj",
    "scheme": "FanControlPlugin"
  },
  "package": {
    "signPaths": [
      "FanControl.bundle/Contents/Resources/SMCHelper/mactools-fan-smc-helper"
    ]
  },
  "capabilities": {
    "primaryPanel": true,
    "componentPanel": false,
    "configuration": true
  },
  "permissions": []
}
